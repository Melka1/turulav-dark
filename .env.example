# Frontend environment variables.
# Copy to .env.local (gitignored) and tweak per machine.

# Base URL of the separate NestJS backend project. Includes the API version
# prefix; endpoint paths in src/api/* and src/mocks/* are relative to this.
VITE_BACKEND_URL=https://5e04-102-213-68-44.ngrok-free.app/api/v1

# When true, the bundle boots MSW and intercepts requests against the contract
# in docs/user/INTEGRATION_PLAN.md §3. Flip to false to talk to the real backend.
VITE_USE_MOCKS=false
