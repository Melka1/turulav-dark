{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend-app && npm install && npm run build",
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/members/:uuid(me|[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12})",
      "destination": "/profile"
    }
  ]
}
